# midware-mcp-client 插件配置
# 这些配置在 OpenClaw 配置文件的 plugins.entries.midware-mcp-client.config 中设置

# midware-mcp-service 的 Streamable HTTP 端点 URL
MCP_SERVICE_URL=http://localhost:9003/mcp

# 用户会话缓存有效期（秒，默认1200）
SESSION_CACHE_TTL_SECONDS=1200

# 提前刷新缓冲时间（秒，默认300）
SESSION_REFRESH_BUFFER_SECONDS=300

# 最大缓存条目数（默认1000）
MAX_CACHE_SIZE=1000

# 请求超时时间（秒，默认30）
REQUEST_TIMEOUT=30
