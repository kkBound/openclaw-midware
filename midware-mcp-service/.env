# Mock模式：true=不调用真实后端，返回模拟数据（开发调试用）
MOCK_MODE=true

# 后端实际API的请求地址前缀（MOCK_MODE=true时可不填）
API_PREFIX=https://api.midware.example.com

# 应用标识（MOCK_MODE=true时可不填）
APP_ID=app_xxx123

# 应用密钥（MOCK_MODE=true时可不填）
APP_SECRET=sec_xxx456

# 获取应用Token的接口完整URL（MOCK_MODE=true时可不填）
APP_TOKEN_URL=https://auth.midware.example.com/oauth/token

# 获取用户文档和临时会话Token的接口URL（MOCK_MODE=true时可不填）
USER_SESSION_URL=https://auth.midware.example.com/api/v1/user/session

# 应用Token缓存有效期（秒，默认3600）
APP_TOKEN_TTL_SECONDS=3600

# MCP服务监听端口（默认3000）
SERVER_PORT=9003

# 日志级别（默认info）
LOG_LEVEL=debug
