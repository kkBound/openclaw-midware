# Mock模式：true=不调用真实后端，返回模拟数据（开发调试用）
MOCK_MODE=true

# 后端实际API的请求地址前缀（MOCK_MODE=true时可不填）
API_PREFIX=http://localhost:8000/ceboshitech/p/midware/api/

# 应用标识（MOCK_MODE=true时可不填）
APP_ID=4252562911289278464

# 应用密钥（MOCK_MODE=true时可不填）
APP_SECRET=9430dc61-02f7-494f-bc99-0f5fe406d74b

# 获取应用Token的接口完整URL（MOCK_MODE=true时可不填）
APP_TOKEN_URL=http://localhost:8000/ceboshitech/p/midware/api/V1.0/token

# 获取用户文档和临时会话Token的接口URL（MOCK_MODE=true时可不填）
USER_SESSION_URL=http://localhost:8000/ceboshitech/p/midware/api/V1.0/agentToken

# 应用Token缓存有效期（秒，默认3600）
APP_TOKEN_TTL_SECONDS=3600

# MCP服务监听端口（默认3000）
SERVER_PORT=9003

# 日志级别（默认info）
LOG_LEVEL=debug
